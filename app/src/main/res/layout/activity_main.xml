<?xml version="1.0" encoding="utf-8"?>
<!--
  854×480 단안 글라스 · 다크 고대비.
  상단바(제목·처음으로) / 바코드 칩 / 입고 위치 히어로 카드 / 상태 배너 / 동작 버튼.
  버튼 텍스트 = WearHF 음성 명령.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="12dp">

    <!-- 상단바 -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_main"
        android:textColor="@color/fg"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/homeButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/homeButton"
        app:layout_constraintTop_toTopOf="@id/homeButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/homeButton"
        style="@style/Widget.Glass.Button.Ghost"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:text="@string/btn_home"
        app:layout_constraintEnd_toStartOf="@id/exitButton"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/exitButton"
        style="@style/Widget.Glass.Button.Ghost"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="@string/btn_exit"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="@color/divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/homeButton" />

    <!-- 바코드 칩 -->
    <LinearLayout
        android:id="@+id/barcodeChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_chip"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_barcode"
            android:textColor="@color/muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/barcodeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="monospace"
            android:text="—"
            android:textColor="@color/fg"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 입고 위치 히어로 카드 (미니맵 + 코드/힌트) -->
    <LinearLayout
        android:id="@+id/heroCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@id/statusText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barcodeChip">

        <io.vasim.glass.WarehouseMapView
            android:id="@+id/warehouseMap"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="14dp"
            android:layout_weight="1.25"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/locationLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="@string/label_location"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/locationText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:autoSizeMaxTextSize="48sp"
                android:autoSizeMinTextSize="20sp"
                android:autoSizeTextType="uniform"
                android:gravity="center"
                android:text=""
                android:textColor="@color/accent"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/hintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text=""
                android:textColor="@color/muted"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/heroCard"
        app:layout_constraintEnd_toEndOf="@id/heroCard"
        app:layout_constraintStart_toStartOf="@id/heroCard"
        app:layout_constraintTop_toTopOf="@id/heroCard" />

    <!-- 상태 배너 -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_pill"
        android:backgroundTint="@color/surface_variant"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingTop="9dp"
        android:paddingEnd="16dp"
        android:paddingBottom="9dp"
        android:text=""
        android:textColor="@color/fg"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 동작 버튼 (text = 음성 명령) -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scanButton"
            style="@style/Widget.Glass.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1.3"
            android:text="@string/btn_scan" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/inboundButton"
            style="@style/Widget.Glass.Button.Tonal"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/btn_inbound" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/inboundItemButton"
            style="@style/Widget.Glass.Button.Tonal"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1.2"
            android:text="@string/btn_inbound_item" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/inboundConfirmButton"
            style="@style/Widget.Glass.Button.Success"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1.3"
            android:text="@string/btn_inbound_confirm" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/outboundButton"
            style="@style/Widget.Glass.Button.Tonal"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:layout_weight="1"
            android:text="@string/btn_outbound" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
